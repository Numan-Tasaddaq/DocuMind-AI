APP_ENV=development
APP_DEBUG=false

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=documind_ai
DB_USER=documind_app
DB_PASSWORD=change_me
DATABASE_URL=postgresql://documind_app:change_me@localhost:5432/documind_ai

# Auth security
JWT_SECRET=change_this_to_a_long_random_secret
JWT_ALGORITHM=HS256
JWT_EXPIRES_MINUTES=30
PASSWORD_HASH_SCHEME=bcrypt
PASSWORD_MIN_LENGTH=8
MAX_LOGIN_ATTEMPTS=5
ACCOUNT_LOCK_MINUTES=15
CORS_ORIGINS=*
