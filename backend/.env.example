APP_ENV=development
APP_DEBUG=false

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=documind_ai
DB_USER=documind_app
DB_PASSWORD=change_me
DATABASE_URL=postgresql://documind_app:change_me@localhost:5432/documind_ai

# Auth security
JWT_SECRET=change_this_to_a_long_random_secret
JWT_ALGORITHM=HS256
JWT_EXPIRES_MINUTES=30
PASSWORD_HASH_SCHEME=bcrypt
PASSWORD_MIN_LENGTH=8
MAX_LOGIN_ATTEMPTS=5
ACCOUNT_LOCK_MINUTES=15
CORS_ORIGINS=*

# Frontend callback for OAuth redirects
FRONTEND_AUTH_CALLBACK_URL=http://127.0.0.1:5500/frontend/index.html
OAUTH_STATE_TTL_SECONDS=600

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://127.0.0.1:8000/api/auth/oauth/google/callback

# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://127.0.0.1:8000/api/auth/oauth/github/callback

# Gemini API
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
